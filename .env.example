# ============================================================================
#  VetApp Outreach Pipeline - Environment Variables
# ----------------------------------------------------------------------------
#  HOW TO USE:
#    1. Copy this file to ".env"  ->  cp .env.example .env   (Windows: copy .env.example .env)
#    2. Fill in your real keys below.
#    3. NEVER commit the real .env file (it is gitignored).
# ============================================================================

# ----------------------------------------------------------------------------
#  EMAIL  (SendGrid)  <-- PRIMARY CHANNEL (active now)
# ----------------------------------------------------------------------------
#  >>> TO CHANGE THE HOST / SENDING GMAIL ID, EDIT "SENDGRID_FROM_EMAIL" BELOW <<<
#  The from-email must be a SendGrid "Verified Single Sender" (can be a Gmail address).
#  Set it up at: https://app.sendgrid.com/settings/sender_auth
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=youraccount@gmail.com
SENDGRID_FROM_NAME=VetApp Team

# ----------------------------------------------------------------------------
#  WHATSAPP  (Twilio)  <-- DISABLED for now (see WHATSAPP_ENABLED in config.py)
# ----------------------------------------------------------------------------
#  >>> TO CHANGE THE WHATSAPP SENDER ID/NUMBER, EDIT "TWILIO_WHATSAPP_FROM" BELOW <<<
#  Keep the "whatsapp:" prefix. Sandbox default shown.
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ----------------------------------------------------------------------------
#  NLP
# ----------------------------------------------------------------------------
NLP_CONFIDENCE_THRESHOLD=0.6
